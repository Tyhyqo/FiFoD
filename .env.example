# PostgreSQL — используется и контейнером db, и приложением через DATABASE_URL
POSTGRES_USER=fifod
POSTGRES_PASSWORD=fifod
POSTGRES_DB=fifod
DATABASE_URL=postgresql+asyncpg://fifod:fifod@db:5432/fifod

# Настройки пула соединений с БД
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Внешний API устройств — ОБЯЗАТЕЛЬНО заполнить перед запуском
EXTERNAL_API_URL=https://external-api.example.com
EXTERNAL_API_TOKEN=your-token-here

# Политика повторов при ошибке внешнего API (HTTP 5xx / success=false)
EXTERNAL_API_RETRY_COUNT=3
EXTERNAL_API_RETRY_DELAY=1.0

# Директория файлов (монтируется через volume в docker-compose)
FILE_DIR=/app/files
