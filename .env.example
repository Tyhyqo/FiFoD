# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Используются и контейнером db, и приложением через DATABASE_URL.
POSTGRES_USER=fifod
POSTGRES_PASSWORD=fifod
POSTGRES_DB=fifod
DATABASE_URL=postgresql+asyncpg://fifod:fifod@db:5432/fifod

# ── Пул соединений с БД ────────────────────────────────────────────────────
DB_POOL_SIZE=10              # Количество постоянных соединений в пуле
DB_MAX_OVERFLOW=20           # Дополнительные соединения сверх DB_POOL_SIZE
DB_POOL_RECYCLE=3600         # Пересоздавать соединения через N секунд (защита от TCP timeout)

# ── Внешний API устройств ───────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО заполнить перед запуском.
EXTERNAL_API_URL=https://external-api.example.com
EXTERNAL_API_TOKEN=your-token-here

# Политика повторов при ошибке внешнего API (HTTP 5xx / success=false)
EXTERNAL_API_RETRY_COUNT=3   # Количество попыток
EXTERNAL_API_RETRY_DELAY=1.0 # Пауза между попытками (секунды)

# ── HTTP-клиент (httpx) ────────────────────────────────────────────────────
HTTP_TIMEOUT_CONNECT=5.0     # Таймаут на установку соединения (сек)
HTTP_TIMEOUT_READ=10.0       # Таймаут ожидания ответа (сек)
HTTP_TIMEOUT_WRITE=10.0      # Таймаут на отправку запроса (сек)
HTTP_TIMEOUT_POOL=5.0        # Таймаут ожидания свободного коннекта из пула (сек)
HTTP_MAX_CONNECTIONS=100     # Максимум одновременных соединений
HTTP_MAX_KEEPALIVE_CONNECTIONS=20  # Максимум keep-alive соединений
HTTP_KEEPALIVE_EXPIRY=30.0   # Время жизни keep-alive соединения (сек)

# ── JWT-авторизация ───────────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО сменить перед запуском в продакшене.
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30   # Время жизни access-токена (минуты)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7      # Время жизни refresh-токена (дни)

# ── Файловая система ───────────────────────────────────────────────────────
# Директория, из которой берутся файлы для привязки к устройствам.
# В Docker монтируется через volume в docker-compose.yml.
FILE_DIR=/app/files

# ── Логирование ────────────────────────────────────────────────────────────
# Допустимые значения: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
