# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=fifod
POSTGRES_PASSWORD=fifod
POSTGRES_DB=fifod
DATABASE_URL=postgresql+asyncpg://fifod:fifod@db:5432/fifod

# ── Пул соединений с БД ────────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ── Внешний API устройств ───────────────────────────────────────────────────
EXTERNAL_API_URL=https://external-api.example.com
EXTERNAL_API_TOKEN=your-token-here
EXTERNAL_API_RETRY_COUNT=3
EXTERNAL_API_RETRY_DELAY=1.0

# ── HTTP-клиент (httpx) ────────────────────────────────────────────────────
HTTP_TIMEOUT_CONNECT=5.0
HTTP_TIMEOUT_READ=10.0
HTTP_TIMEOUT_WRITE=10.0
HTTP_TIMEOUT_POOL=5.0
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
HTTP_KEEPALIVE_EXPIRY=30.0

# ── JWT-авторизация ───────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Файловая система ───────────────────────────────────────────────────────
FILE_DIR=/app/files

# ── Логирование ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
